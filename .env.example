# Google-tags voor SEA-meting (optioneel).
# Vul deze in Vercel in onder Project → Settings → Environment Variables.
# Zonder deze waarden toont de cookiebanner niet en wordt er niets van Google geladen.

# GA4 meet-ID (vorm: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Ads conversie-ID (vorm: AW-XXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads conversie-label van de "Lead/contact"-conversieactie (vorm: AbC-D_efGhIjK)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
